<?xml version="1.0"?>
<!-- origin мШИм†Ь: geometryмЩА joint мЬДмєШ/мЮРмДЄл•Љ мІАм†Х -->
<robot name="origins">
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
    </visual>
  </link>

  <link name="right_leg">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <!-- origin: мЭі лІБнБђмЭШ мЛЬк∞Б мЪФмЖМл•Љ лІБнБђ мҐМнСЬк≥ДмЧРмДЬ мЭілПЩ/нЪМм†Д -->
      <!-- rpy: roll, pitch, yaw (rad), xyz: x y z мЬДмєШ -->
      <origin rpy="0 1.57075 0" xyz="0 0 -0.3"/>
    </visual>
  </link>

  <joint name="base_to_right_leg" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
    <!-- joint origin: child лІБнБђмЭШ кЄ∞м§А мЬДмєШл•Љ лґАл™® лІБнБђ кЄ∞м§АмЬЉл°Ь м†ХмЭШ -->
    <origin xyz="0 -0.22 0.25"/>
  </joint>

</robot>
