<?xml version="1.0" ?>
<!--
  트랙형 이동 로봇 URDF v5 (3차 실측 반영)
  ==========================================================
  확정 구조 (지면 기준):
    - 1층 받침대 윗면 0.020 (두께 6.5mm)
    - OpenCR 보드 0.055 (1층 윗면 +3.5cm), IMU는 보드 정중앙
      IMU 축: x=전방(카메라), y=좌, z=상(라이다) - OpenCR/TB3 표준
    - 2층 받침대 윗면 0.0945 (천장 -9cm +두께)
    - 천장 받침대 윗면 0.178 (실측)
    - 라이다 받침 윗면 0.224 (+4.6cm), 회전부 2.4cm → 꼭대기 0.248
    - 카메라 중심 0.148 (실측 약 15cm, 0.314rad 전방 기울임)
  트랙: 외곽 앞뒤 20cm(-0.10~+0.10), 안쪽 프로파일 17cm,
    좌우 안쪽면 간격 12cm → 트랙 중심 y=±0.08, 전폭 20cm
    → 주행 기하 wheel_separation 0.16으로 반영
  트랙 전후: 앞끝이 1층 받침대 앞끝(0.105)에서 0.5cm 뒤(0.10),
    뒤끝은 1층 뒤끝(-0.09)보다 뒤(-0.10)
  2층 배치(뒤→앞): USB허브 - Jetson AGX Xavier - 보조배터리 밀착
  카메라: D435 - depth/color/optical 프레임 정의 (내장 IMU 없음)
  물리: 트랙 중앙 숨김 구동륜 2개(디퍼렌셜) + 캐스터 구 4개(마찰 0.1)
-->
<robot name="tracked_robot">

  <material name="black"><color rgba="0.08 0.08 0.08 1.0"/></material>
  <material name="dark"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="silver"><color rgba="0.75 0.75 0.78 1.0"/></material>
  <material name="board_green"><color rgba="0.1 0.35 0.15 1.0"/></material>

  <!-- ================= BASE ================= -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <!-- 다이나믹셀 XC430 x2 (뒷바퀴 구동, 시각 전용) -->
    <visual>
      <origin xyz="-0.048 0.047 0"/>
      <geometry><box size="0.0465 0.0285 0.034"/></geometry>
      <material name="dark"/>
    </visual>
    <visual>
      <origin xyz="-0.048 -0.047 0"/>
      <geometry><box size="0.0465 0.0285 0.034"/></geometry>
      <material name="dark"/>
    </visual>
    <inertial>
      <origin xyz="-0.03 0 0" rpy="0 0 0"/>
      <mass value="0.30"/>
      <inertia ixx="3.1e-4" ixy="0" ixz="0" iyy="9.6e-4" iyz="0" izz="1.15e-3"/>
    </inertial>
  </link>

  <!-- ================= 트랙 (시각 전용) ================= -->
  <!-- 외곽 20cm, 안쪽 프로파일 17cm(끝 반경 2.5cm), 안쪽면 간격 12cm -->
  <joint name="track_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="track_left_link"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
  </joint>
  <link name="track_left_link">
    <visual>
      <geometry><box size="0.12 0.04 0.08"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- 앞 아이들러 허브 (안쪽 프로파일 반경 2.5cm) -->
      <origin xyz="0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.042" radius="0.025"/></geometry>
      <material name="dark"/>
    </visual>
    <visual><!-- 뒤 구동 스프라켓 허브 -->
      <origin xyz="-0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.042" radius="0.025"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01"/>
      <geometry><box size="0.20 0.04 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="1.0e-4" ixy="0" ixz="0" iyy="5.6e-4" iyz="0" izz="5.1e-4"/>
    </inertial>
  </link>

  <joint name="track_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="track_right_link"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
  </joint>
  <link name="track_right_link">
    <visual>
      <geometry><box size="0.12 0.04 0.08"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.042" radius="0.025"/></geometry>
      <material name="dark"/>
    </visual>
    <visual>
      <origin xyz="-0.06 0 0" rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.042" radius="0.025"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01"/>
      <geometry><box size="0.20 0.04 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="1.0e-4" ixy="0" ixz="0" iyy="5.6e-4" iyz="0" izz="5.1e-4"/>
    </inertial>
  </link>

  <!-- ================= 구동륜 (숨김, 물리 전용, 트랙 중심선) ================= -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="wheel_left_link">
    <collision>
      <origin rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.036" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="5.1e-5" ixy="0" ixz="0" iyy="5.1e-5" iyz="0" izz="8.0e-5"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.08 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="wheel_right_link">
    <collision>
      <origin rpy="-1.570796 0 0"/>
      <geometry><cylinder length="0.036" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="5.1e-5" ixy="0" ixz="0" iyy="5.1e-5" iyz="0" izz="8.0e-5"/>
    </inertial>
  </link>

  <!-- ================= 캐스터 구 4개 (트랙 끝 아래, 마찰 0.1) ================= -->
  <joint name="caster_fl_joint" type="fixed">
    <parent link="base_link"/><child link="caster_fl_link"/>
    <origin xyz="0.088 0.08 -0.028"/>
  </joint>
  <link name="caster_fl_link">
    <collision><geometry><sphere radius="0.012"/></geometry></collision>
    <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
  </link>

  <joint name="caster_fr_joint" type="fixed">
    <parent link="base_link"/><child link="caster_fr_link"/>
    <origin xyz="0.088 -0.08 -0.028"/>
  </joint>
  <link name="caster_fr_link">
    <collision><geometry><sphere radius="0.012"/></geometry></collision>
    <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
  </link>

  <joint name="caster_rl_joint" type="fixed">
    <parent link="base_link"/><child link="caster_rl_link"/>
    <origin xyz="-0.088 0.08 -0.028"/>
  </joint>
  <link name="caster_rl_link">
    <collision><geometry><sphere radius="0.012"/></geometry></collision>
    <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
  </link>

  <joint name="caster_rr_joint" type="fixed">
    <parent link="base_link"/><child link="caster_rr_link"/>
    <origin xyz="-0.088 -0.08 -0.028"/>
  </joint>
  <link name="caster_rr_link">
    <collision><geometry><sphere radius="0.012"/></geometry></collision>
    <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
  </link>

  <!-- ================= 1층 받침대 (윗면 0.02, 두께 6.5mm) + OpenCR ================= -->
  <!-- 앞끝 0.105 (트랙 앞끝 0.10 + 0.5cm), 중심 x 0.0075, 중심 z 0.0168 -->
  <joint name="plate1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="plate1_link"/>
    <origin xyz="0.0075 0 -0.0232" rpy="0 0 0"/>
  </joint>
  <link name="plate1_link">
    <visual>
      <geometry><box size="0.195 0.115 0.0065"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- OpenCR 10.2 x 7.4cm, 앞끝에서 2.5cm 뒤, 1층 윗면 +3.5cm -->
      <origin xyz="0.0215 0 0.0382"/>
      <geometry><box size="0.102 0.074 0.008"/></geometry>
      <material name="board_green"/>
    </visual>
    <collision><geometry><box size="0.195 0.115 0.0065"/></geometry></collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="4.8e-4" iyz="0" izz="6.4e-4"/>
    </inertial>
  </link>

  <!-- ================= 2층 받침대 (윗면 0.0945) ================= -->
  <!-- 뒤→앞: USB허브 - Jetson - 배터리 밀착, 앞끝에 볼마운트 -->
  <joint name="plate2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="plate2_link"/>
    <origin xyz="0.0075 0 0.0513" rpy="0 0 0"/>
  </joint>
  <link name="plate2_link">
    <visual>
      <geometry><box size="0.195 0.12 0.0065"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- USB 3.0 허브 (최후방, 17 x 2 x 5cm) -->
      <origin xyz="-0.0875 0 0.0283"/>
      <geometry><box size="0.02 0.17 0.05"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- Jetson AGX Xavier (허브에 밀착) -->
      <origin xyz="-0.025 0 0.0358"/>
      <geometry><box size="0.105 0.095 0.065"/></geometry>
      <material name="dark"/>
    </visual>
    <visual><!-- 보조 배터리 (Jetson 앞에 밀착) -->
      <origin xyz="0.0475 0 0.0256"/>
      <geometry><box size="0.04 0.10 0.045"/></geometry>
      <material name="dark"/>
    </visual>
    <visual><!-- 카메라 볼마운트: 앞끝에서 0.5cm 뒤, 지름 2.5cm, 높이 4cm -->
      <origin xyz="0.08 0 0.0233"/>
      <geometry><cylinder length="0.04" radius="0.0125"/></geometry>
      <material name="silver"/>
    </visual>
    <visual><!-- 1층→2층 기둥 -->
      <origin xyz="0.09 0.05 -0.0373"/><geometry><cylinder length="0.068" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0.09 -0.05 -0.0373"/><geometry><cylinder length="0.068" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.09 0.05 -0.0373"/><geometry><cylinder length="0.068" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.09 -0.05 -0.0373"/><geometry><cylinder length="0.068" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <collision><geometry><box size="0.195 0.12 0.0065"/></geometry></collision>
    <inertial>
      <origin xyz="-0.02 0 0.03"/>
      <mass value="1.34"/>
      <inertia ixx="2.3e-3" ixy="0" ixz="0" iyy="4.9e-3" iyz="0" izz="5.9e-3"/>
    </inertial>
  </link>

  <!-- ================= 천장 받침대 (윗면 0.178) + 라이다 받침 ================= -->
  <joint name="plate_top_joint" type="fixed">
    <parent link="base_link"/>
    <child link="plate_top_link"/>
    <origin xyz="0.0075 0 0.1348" rpy="0 0 0"/>
  </joint>
  <link name="plate_top_link">
    <visual>
      <geometry><box size="0.19 0.135 0.0065"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- 2층→천장 기둥 -->
      <origin xyz="0.09 0.055 -0.0418"/><geometry><cylinder length="0.077" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0.09 -0.055 -0.0418"/><geometry><cylinder length="0.077" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.09 0.055 -0.0418"/><geometry><cylinder length="0.077" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.09 -0.055 -0.0418"/><geometry><cylinder length="0.077" radius="0.004"/></geometry><material name="silver"/>
    </visual>
    <visual><!-- 라이다 받침 기둥 (천장 위 4.6cm) -->
      <origin xyz="0.025 0.035 0.0243"/><geometry><cylinder length="0.042" radius="0.003"/></geometry><material name="dark"/>
    </visual>
    <visual>
      <origin xyz="0.025 -0.035 0.0243"/><geometry><cylinder length="0.042" radius="0.003"/></geometry><material name="dark"/>
    </visual>
    <visual>
      <origin xyz="-0.05 0 0.0243"/><geometry><cylinder length="0.042" radius="0.003"/></geometry><material name="dark"/>
    </visual>
    <visual><!-- 라이다 받침 플레이트 (윗면 0.224) -->
      <origin xyz="-0.0025 0 0.0473"/>
      <geometry><box size="0.11 0.09 0.004"/></geometry>
      <material name="black"/>
    </visual>
    <visual><!-- 라이다 벨트 구동 모터 (카메라 쪽 전방, 받침 밑) -->
      <origin xyz="0.0525 0 0.030"/>
      <geometry><cylinder length="0.03" radius="0.012"/></geometry>
      <material name="silver"/>
    </visual>
    <collision><geometry><box size="0.19 0.135 0.0065"/></geometry></collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="1.8e-4" ixy="0" ixz="0" iyy="3.6e-4" iyz="0" izz="5.4e-4"/>
    </inertial>
  </link>

  <!-- ================= IMU (OpenCR 보드 정중앙) ================= -->
  <!-- x=전방(카메라), y=좌, z=상(라이다) - OpenCR/TB3 표준 축 -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.029 0 0.015" rpy="0 0 0"/>
  </joint>
  <link name="imu_link"/>

  <!-- ================= LiDAR (RPLIDAR A1M8) ================= -->
  <!-- 받침 윗면 0.224, 회전부 2.4cm → 꼭대기 0.248. 스캔면 0.236 -->
  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.005 0 0.196" rpy="0 0 0"/>
  </joint>
  <link name="base_scan">
    <visual>
      <geometry><cylinder length="0.024" radius="0.035"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.024" radius="0.035"/></geometry>
    </collision>
    <inertial>
      <mass value="0.19"/>
      <inertia ixx="6.7e-5" ixy="0" ixz="0" iyy="6.7e-5" iyz="0" izz="1.2e-4"/>
    </inertial>
  </link>

  <!-- ================= Camera: Intel RealSense D435 ================= -->
  <!-- 중심 지면 0.148 (실측 ~15cm), 전방 0.314rad 기울임
       프레임 구성 (realsense2 표준 근사):
       camera_link(본체 중심) → camera_depth_frame(동일)
         → camera_depth_optical_frame(광학 회전)
       → camera_color_frame(y +1.5cm) → camera_color_optical_frame -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.0875 0 0.108" rpy="0 0.314 0"/>
  </joint>
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
      <material name="silver"/>
    </visual>
    <visual><!-- 전면 렌즈 바 -->
      <origin xyz="0.0128 0 0"/>
      <geometry><box size="0.002 0.078 0.016"/></geometry>
      <material name="black"/>
    </visual>
    <collision><geometry><box size="0.025 0.09 0.025"/></geometry></collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="1.0e-6" ixy="0" ixz="0" iyy="1.0e-6" iyz="0" izz="1.0e-6"/>
    </inertial>
  </link>

  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_depth_frame"/>

  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.570796 0 -1.570796"/>
  </joint>
  <link name="camera_depth_optical_frame"/>

  <joint name="camera_color_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_frame"/>
    <origin xyz="0 0.015 0" rpy="0 0 0"/>
  </joint>
  <link name="camera_color_frame"/>

  <joint name="camera_color_optical_joint" type="fixed">
    <parent link="camera_color_frame"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.570796 0 -1.570796"/>
  </joint>
  <link name="camera_color_optical_frame"/>

  <!-- ================================================== -->
  <!-- ================= GAZEBO 설정 ==================== -->
  <!-- ================================================== -->

  <gazebo reference="track_left_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="track_right_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="plate1_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="plate2_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="plate_top_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="base_scan"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="camera_link"><material>Gazebo/Grey</material></gazebo>

  <gazebo reference="wheel_left_link">
    <mu1>5.0</mu1><mu2>5.0</mu2>
    <kp>500000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="wheel_right_link">
    <mu1>5.0</mu1><mu2>5.0</mu2>
    <kp>500000.0</kp><kd>10.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

  <gazebo reference="caster_fl_link"><mu1>0.1</mu1><mu2>0.1</mu2></gazebo>
  <gazebo reference="caster_fr_link"><mu1>0.1</mu1><mu2>0.1</mu2></gazebo>
  <gazebo reference="caster_rl_link"><mu1>0.1</mu1><mu2>0.1</mu2></gazebo>
  <gazebo reference="caster_rr_link"><mu1>0.1</mu1><mu2>0.1</mu2></gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.16</wheel_separation>
      <wheel_diameter>0.08</wheel_diameter>
      <max_wheel_torque>25</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="joint_states" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>30</update_rate>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- OpenCR IMU -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><remapping>~/out:=imu</remapping></ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- RPLIDAR A1M8 -->
  <gazebo reference="base_scan">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min><max>12.0</max><resolution>0.01</resolution>
        </range>
        <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- D435 뎁스 카메라 (depth FOV 87도) -->
  <gazebo reference="camera_link">
    <sensor name="depth_camera" type="depth">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.5184</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.105</near><far>10.0</far></clip>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <camera_name>camera</camera_name>
        <frame_name>camera_depth_optical_frame</frame_name>
        <min_depth>0.105</min_depth>
        <max_depth>10.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

</robot>
