<?xml version="1.0"?>
<robot name="my_f" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="width" value="0.4" />       <xacro:property name="length" value="1.0" />      <xacro:property name="wheel_length" value="0.1" />      <xacro:property name="body_high" value="0.1" />  <xacro:property name="wheelrad" value="${body_high+width}" />  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  
  <xacro:macro name="cylinder_inertial_z" params="mass r l">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3*r*r + l*l)/12}" ixy="0" ixz="0"
               iyy="${mass*(3*r*r + l*l)/12}" iyz="0"
               izz="${mass*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertial_x" params="mass r l">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*r*r/2}" ixy="0" ixz="0"
               iyy="${mass*(3*r*r + l*l)/12}" iyz="0"
               izz="${mass*(3*r*r + l*l)/12}"/>
    </inertial>
  </xacro:macro>
  
  <xacro:macro name="wheel" params="prefix reflect">
    <joint name="${prefix}_wheel_joint" type="continuous">
      <axis xyz="0 0 ${reflect*1}"/> <parent link="base_link"/>  <child link="${prefix}_wheel"/> <origin xyz="0 ${reflect*(body_high+width)} 0" rpy="${reflect*1.570796} 0 0"/>
    </joint>
  </xacro:macro>
  
  <link name="base_footprint"/>
  
  <joint name="base_footprint_to_base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheelrad}" rpy="0 0 0"/>
  </joint>
  
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="${length}" radius="${width}"/>
      </geometry>
      <origin xyz="0 0 ${body_high}" rpy="0 1.570796 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${length}" radius="${width}"/>
      </geometry>
      <origin xyz="0 0 ${body_high}" rpy="0 1.570796 0"/>
    </collision>
    <xacro:cylinder_inertial_z mass="10" r="${width}" l="${length}"/>
  </link>
    
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="${wheel_length}" radius="${wheelrad}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${wheel_length}" radius="${wheelrad}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertial_x mass="1" r="${wheelrad}" l="${wheel_length}"/>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="${wheel_length}" radius="${wheelrad}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="${wheel_length}" radius="${wheelrad}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertial_x mass="1" r="${wheelrad}" l="${wheel_length}"/>
  </link>
  
  <xacro:wheel prefix="right" reflect="1"/>
  <xacro:wheel prefix="left" reflect="-1"/>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.4 0 ${-width + body_high}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="caster_wheel">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
  </gazebo>
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <update_rate>30</update_rate>
      
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      
      <wheel_separation>${(body_high + width) * 2}</wheel_separation> 
      <wheel_diameter>${wheelrad * 2}</wheel_diameter>   
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>
  
</robot>